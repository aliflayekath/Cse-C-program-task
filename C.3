#include <stdio.h>

int main()
{
    int n, k;
    int a[50];
    int i;
    int ans = 0;

    scanf("%d%d", &n, &k);

    for(i = 0; i < n; i++)
    {
        scanf("%d", &a[i]);
    }

    for(i = 0; i < n; i++)
    {
        if(a[i] > 0)
        {
            if(a[i] >= a[k - 1])
            {
                ans++;
            }
        }
    }

    printf("%d", ans);

    return 0;
}
