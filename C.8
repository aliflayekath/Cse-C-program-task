#include <stdio.h>
#include <ctype.h>

int main()
{
    char s[101];
    int i, u = 0, l = 0;

    scanf("%s", s);

    for(i = 0; s[i] != '\0'; i++)
    {
        if(isupper(s[i]))
            u++;
        else
            l++;
    }

    for(i = 0; s[i] != '\0'; i++)
    {
        if(u > l)
            s[i] = toupper(s[i]);
        else
            s[i] = tolower(s[i]);
    }

    printf("%s", s);
    return 0;
}
