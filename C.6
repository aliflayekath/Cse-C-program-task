#include <stdio.h>
#include <string.h>

int main()
{
    char s[101];
    int i, j, c = 0;

    scanf("%s", s);

    for(i = 0; i < strlen(s); i++)
    {
        for(j = 0; j < i; j++)
        {
            if(s[i] == s[j])
                break;
        }

        if(i == j)
            c++;
    }

    if(c % 2 == 0)
        printf("CHAT WITH HER!");
    else
        printf("IGNORE HIM!");

    return 0;
}
