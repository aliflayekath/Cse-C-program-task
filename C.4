#include <stdio.h>

int main()
{
    int a[5][5];
    int i, j;
    int row, col;

    for(i = 0; i < 5; i++)
    {
        for(j = 0; j < 5; j++)
        {
            scanf("%d", &a[i][j]);

            if(a[i][j] == 1)
            {
                row = i;
                col = j;
            }
        }
    }

    int moves = 0;

    if(row > 2)
        moves = moves + (row - 2);
    else
        moves = moves + (2 - row);

    if(col > 2)
        moves = moves + (col - 2);
    else
        moves = moves + (2 - col);

    printf("%d", moves);

    return 0;
}
