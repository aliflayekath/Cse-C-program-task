#include <stdio.h>
#include <ctype.h>

int main()
{
    char a[101], b[101];
    int i;

    scanf("%s", a);
    scanf("%s", b);

    for(i = 0; i < strlen(a); i++)
    {
        a[i] = tolower(a[i]);
        b[i] = tolower(b[i]);
    }

    if(str(a,b) < 0)
        printf("-1");
    else if(str(a,b) > 0)
        printf("1");
    else
        printf("0");

    return 0;
}
